# === P0 新增：反爬蟲配置 ===
RETRY_MAX = 5
RETRY_BASE_DELAY = 2.0  # 指數退避基準 delay
REQUEST_TIMEOUT = 45000  # 45 秒
BROWSER_LAUNCH_TIMEOUT = 60000  # 60 秒

