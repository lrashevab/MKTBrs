except ImportError:
    NEGATIVE_WORDS = ["雷", "爛", "騙", "貴", "沒效", "後悔", "盤子", "割韭菜", "退費", "話術", "假", "套路", "PUA"]
    SENTIMENT_CATEGORIES = {
        "產品技術觀感": {"keywords": ["話術", "套路", "罐頭", "背稿", "假", "PUA"], "polarity": "負面 (覺得假)"},
        "情緒焦慮": {"keywords": ["尷尬", "自卑", "焦慮", "緊張", "沒自信"], "polarity": "中性/焦慮"},
