# ===========================================
# 環境變數設定檔
# ===========================================
# 請複製此檔為 .env 並填入實際的金鑰
# 程式會自動讀取 .env 或 system.env
# ===========================================

# === Gemini API 金鑰（必填）===
# 申請網址：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# === YouTube Data API（金鑰，選填）===
# 如需 YouTube 爬蟲功能，請至此申請：https://console.cloud.google.com/
# YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY_HERE

# === 系統設定 ===
DEFAULT_OUTPUT_DIR=reports
LOG_LEVEL=INFO
